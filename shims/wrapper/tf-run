#!/usr/bin/env bash
# tf-run — universal wrapper. Brackets ANY agent/command with telemetry.
#
#   tf-run --runtime codex --task "refactor auth" -- codex exec "refactor the auth module"
#   tf-run --runtime open-claw --task "add tests"  -- claw run ./task.md
#   tf-run --runtime manus --task "market report" --coarse -- ./dispatch_manus.sh
#
# Emits: started -> (heartbeat every 30s while running) -> done|error.
SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
export TF_SHIM_DIR="$SCRIPT_DIR"
source "$SCRIPT_DIR/tf_client.sh" 2>/dev/null || { export TF_SHIM_DIR="$SCRIPT_DIR/.."; source "$SCRIPT_DIR/../tf_client.sh"; }

RUNTIME="cli"; TASK=""; COARSE=0; AGENT=""
while [ $# -gt 0 ]; do case "$1" in
  --runtime) RUNTIME="$2"; shift 2;;
  --agent) AGENT="$2"; shift 2;;
  --task) TASK="$2"; shift 2;;
  --coarse) COARSE=1; shift;;       # cloud black box: start/end only
  --) shift; break;;
  *) break;;
esac; done
export TF_RUNTIME="$RUNTIME"
export TF_AGENT="$AGENT"
export TF_SESSION="${TF_SESSION:-${AGENT:-$RUNTIME}-$(date +%s)-$RANDOM}"

[ $# -eq 0 ] && { echo "usage: tf-run --runtime X --task Y -- <command...>"; exit 2; }

TF_WITH_PROFILE=1 tf_emit started --task "$TASK" --step "launching: $*"

# background heartbeat (skipped for coarse cloud runs)
HB_PID=""
if [ "$COARSE" -eq 0 ]; then
  ( while true; do sleep 30; tf_emit running --task "$TASK" --step "working…"; done ) &
  HB_PID=$!
fi

LOG="$(mktemp)"
"$@" 2>&1 | tee "$LOG"
CODE=${PIPESTATUS[0]}
[ -n "$HB_PID" ] && kill "$HB_PID" 2>/dev/null

if [ "$CODE" -eq 0 ]; then
  tf_emit done --task "$TASK" --step "exit 0" \
    ${TF_CAPTURE_CONTENT:+--output "$(tail -c 4000 "$LOG")"}
else
  tf_emit error --task "$TASK" --step "exit $CODE" \
    ${TF_CAPTURE_CONTENT:+--output "$(tail -c 4000 "$LOG")"}
fi
rm -f "$LOG"
exit "$CODE"
