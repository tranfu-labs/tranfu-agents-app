# 本地 Docker Compose 可复制为 .env: cp .env.example .env
# Coolify 部署时在应用环境变量里设置这些值即可。

# === 写入侧（必填）===
# 团队写入密钥(团队成员上报用同一个)
TF_KEY=请改成一串随机密钥

# === Coolify / Traefik 入口 ===
# 容器内部端口固定为 8788。Coolify 里给 server service 配 Domain 时使用:
# https://你的域名:8788

# === 看板读路径缓存（可选）===
# /api/state 与 /api/state/stream 共用的进程内快照缓存 TTL(秒,float)。默认 1.5;生产建议 0.5~3.0。
#TF_STATE_TTL=1.5
# 纯心跳 last_seen 批量写入间隔(秒,float)。默认 15;设 0 可恢复每次心跳即时写库。
#TF_HEARTBEAT_BATCH_SECONDS=15

# === 身份归因（可选，TATP §4 / ADR-0011）===
# 开启后每条上报必须带有效 X-TF-Token(且令牌绑定的 operator 与上报一致),否则 403。
# 关闭时(默认)允许 operator 自证,但看板标记为"未验证"。
# 用 `POST /v1/enroll`(带 TF_KEY)为每个成员签发一次性令牌,成员存入自己的 TF_TOKEN。
#TF_REQUIRE_TOKEN=1

# === 读侧鉴权（内容捕获的硬前提，TATP §5 / ADR-0012）===
# 只要打开 input/output/instructions/memory 上报,就必须先声明读侧已受保护,
# 否则服务端会丢弃这些敏感字段不予存储。二选一:
#   - 走边缘鉴权(Cloudflare Access / Caddy basic auth,见 DEPLOY.md D 节)时,设 TF_READ_AUTH=1 声明已就位
#   - 或设置应用内只读令牌 TF_READ_KEY(非空即视为读侧受保护)
#TF_READ_AUTH=1
#TF_READ_KEY=请改成另一串随机密钥

# === 后台清理台（可选，默认关闭）===
# /admin 和 /api/admin/* 使用独立管理钥匙,不复用团队上报用的 TF_KEY。
# Coolify Compose 部署会通过 SERVICE_PASSWORD_64_ADMIN 自动生成 TF_ADMIN_KEY;
# 本地开发用 `openssl rand -hex 32` 生成强随机值(别用 devadmin 之类易猜口令)。未设置时管理接口一律 403。
#TF_ADMIN_KEY=用 openssl rand -hex 32 生成
# 回收站批次保留天数;过期批次真删,审计行保留。
#TF_TRASH_DAYS=30
# 单次删除超过该行数或跨多个 operator 时,后台要求手输实际行数确认。
#TF_ADMIN_MAX_ROWS=200

# === 管理接口防爆破 / 反代真实 IP（可选）===
# 管理接口按真实客户端 IP 限流。部署在 Traefik / Coolify 等可信反代之后时,
# 必须开 TF_TRUST_PROXY=1,限流才按真实 IP 生效,否则所有人共用反代 IP 会
# 「一人触发、全员被封」。⚠ 仅在确认前置有可信反代时开 —— 否则攻击者自带
# X-Forwarded-For 即可伪造 IP 绕过限流。
#TF_TRUST_PROXY=1
# 同一来源 TF_ADMIN_RATE_WINDOW 秒内验钥失败超过 TF_ADMIN_RATE_MAX 次后进入封锁,
# 封锁时长从 TF_ADMIN_LOCK_BASE 起指数翻倍、封顶 TF_ADMIN_LOCK_MAX(单位秒)。
#TF_ADMIN_RATE_MAX=5
#TF_ADMIN_RATE_WINDOW=60
#TF_ADMIN_LOCK_BASE=30
#TF_ADMIN_LOCK_MAX=3600
# HTTPS 生产部署设 1 以发送 HSTS 响应头(经可信反代且 X-Forwarded-Proto=https 时会自动发)。
#TF_HSTS=1

# === SKILLS 公司库目录（可选）===
# SKILLS 页的公司库采纳漏斗默认读取 tranfu-skills GitHub release catalog。
# 如果部署机器不能访问 GitHub release,把它指向内网镜像的 index.json。
#TF_SKILLS_CATALOG_URL=https://你的域名/catalog/index.json

# === Token 用量监控（可选）===
# 默认只展示演示数据。接真实分发平台时,把下面四项填好即可。
#TF_TOKEN_USAGE_BASE_URL=https://api.tranfu.com
#TF_TOKEN_USAGE_PATH=/api/data/keys
#TF_TOKEN_USAGE_ACCESS_TOKEN=分发平台访问令牌
#TF_TOKEN_USAGE_COOKIE=分发平台登录 Cookie（仅建议本地预览临时使用）
#TF_TOKEN_USAGE_USER_ID=分发平台用户ID
#TF_TOKEN_USAGE_TIMEOUT=15
#TF_TOKEN_USAGE_CACHE_TTL=90
#TF_TOKEN_USAGE_DEMO=0
